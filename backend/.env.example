# Environment
ENVIRONMENT=development

# Databricks Configuration (for local development)
# Get these from your Databricks workspace
DATABRICKS_HOST=your-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=dapi_your_personal_access_token

# App Configuration
APP_NAME=CSM Dashboard
DEBUG=true

# Optional: CSM panel NPS/CSAT drill-out links
# FRESHDESK_PORTAL_BASE=https://yourorg.freshdesk.com
# SURVEY_MONKEY_RESPONSE_URL_TEMPLATE=https://example.com/path/{response_id}
